# Postgres (docker-compose espone la 5437 sull'host).
# Se lanci tutto con `docker compose up` questo valore viene ignorato:
# app/worker usano automaticamente postgres:5432 (rete interna Docker).
DATABASE_URL=postgres://sologm:sologm@localhost:5437/sologm

# Auth.js — genera con: openssl rand -base64 32
AUTH_SECRET=

# Credenziali dell'utente singolo creato da `npm run db:seed`
# (in alternativa, se il DB non ha ancora utenti, si può usare /register)
APP_USER_FIRST_NAME=
APP_USER_LAST_NAME=
APP_USER_EMAIL=
APP_USER_PASSWORD=

# Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_GM=claude-opus-4-8
ANTHROPIC_MODEL_SUMMARY=claude-opus-4-8

# Soglia di token non riassunti oltre cui si accoda l'update-summary
SUMMARY_TRIGGER_TOKENS=25000

# Embeddings (Voyage AI, voyage-3.5, 1024 dimensioni)
# ⚠️ Cambiare provider o modello richiede di reindicizzare tutti i documenti:
# gli embeddings non sono confrontabili tra provider e la colonna vector(1024)
# vincola la dimensione.
VOYAGE_API_KEY=
EMBEDDINGS_PROVIDER=voyage  # voyage | ollama
# Solo per EMBEDDINGS_PROVIDER=ollama (il modello deve produrre 1024 dimensioni,
# es. bge-m3 o mxbai-embed-large)
OLLAMA_EMBED_MODEL=
# Solo se Ollama gira fuori da Docker (avvio manuale senza `docker compose up`).
# Con `docker compose up` questo valore viene ignorato: app/worker/ollama-pull
# usano automaticamente http://ollama:11434 (rete interna Docker), e il
# comando `ollama pull` per scaricare OLLAMA_EMBED_MODEL parte da solo.
#OLLAMA_HOST=http://localhost:11434

# Upload PDF
MAX_PDF_MB=100
